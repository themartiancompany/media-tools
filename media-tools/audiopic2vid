_global_variables() {
	input_sound=""
	input_pictures=()
  output_video=""
}

_audiopic2vid() {
  local \
    _output_video="${1}" \
    _input_sound="${2}" \
    _input_pictures=() \
    _mktemp_opts=() \
    _ffmpeg_opts=() \
    _pic \
    _length
  shift \
    2
  _input_pictures+=(
    "$@"
  )
  _length="$(
    medialength \
      "${_input_sound}")"
  echo \
    "${_length}"
  echo \
    "${#_input_pictures[@]}"
  _pic_length="$((
    "${_length}" /
      "${#_input_pictures[@]}" ))"
  for _pic in "${_input_pictures[@]}"; do
    ffmpeg_opts+=(
      -loop
        "1"
      -t
        "${_pic_length}"
      -i
        "${_pic}"
    )
  done
  ffmpeg_opts+=(
    -i
      "${_input_sound}"
    -c:v
      "libx264"
    -tune
      "stillimage"
    -c:a
      "aac"
    -b:a
      "48k"
    -pix_fmt
      "yuv420p"
    -shortest
  )
  ffmpeg \
    "${_ffmpeg_opts[@]}" \
    "${_output_video}"
}

_usage() {
  local \
    _exit="${1}" \
    _line \
    _text
  _text=(
    "Create slideshow with sound."
    ""
    "  usage:"
    "    audiopic2vid"
    "      <output-video>"
    "      <input-sound>"
    "      [input-picture]"
    ""
    "  options:"
    "    -h          This help."
    ""
  )
  printf \
    "%s\n" \
    "${_text[@]}"
  exit \
    "${_exit}"
}

_cmdline_parse() {
  local \
    _args=() \
    _msg=()
  _args+=(
    "$@"
  )
  if [[ " ${_args[*]} " == *" -h "* ||
        " ${_args[*]} " == *" --help "* ]]; then
    _usage \
      0
  fi
  if (( "${#_args[@]}" < 3 )); then
    _msg=(
      "Missing argument."
    )
    echo \
      "${_msg[*]}" \
      1>&2
    _usage \
      1
  fi
}

_input_sound_check() {
  local \
    _msg=()
  if [[ ! -e "${input_sound}" ]]; then
    _msg=(
      "Input sound file"
      "'${input_sound}' does not exist."
    )
    echo \
      "${_msg[*]}" \
      1>&2
    exit \
      1
  else
    input_sound="$(
      realpath \
        "${input_sound}")"
  fi
}

# Shows configuration options.
_show_config() {
  _msg_info "audiopic2vid configuration"
  _msg_info "                Make date:   ${scale_date}"
  _msg_info "              Output file:   ${out_file}"
  _msg_info "         Input sound file:   ${input_sound}"
  _msg_info "           Input pictures:   ${input_pictures[*]}"
}

_global_variables
_cmdline_parse \
  "$@"
output_video="${1}"
input_sound="${2}"
_input_sound_check
shift \
  2
input_pictures=(
  "$@"
)
_show_config
app_opts=(
  "${output_video}"
  "${input_sound}"
  "${input_pictures[@]}"
)
_audiopic2vid \
  "${app_opts[@]}"
